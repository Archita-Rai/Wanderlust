<% layout("/layouts/boilerplate")-%>
<!-- <h3>All Listings</h3> -->
<!-- <form method="get" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->
<div class="filter-main">
  <div id="filters" class="filter-options">
    <div class="filter">
      <a href="/listings/category/Trending" class="category-link-reset">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Rooms" class="category-link-reset">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Iconic cities" class="category-link-reset">
        <div><i class="fa-solid fa-mountain-city"></i></div>
        <p>Iconic cities</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Mountains" class="category-link-reset">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Castles" class="category-link-reset">
        <div><i class="fa-brands fa-fort-awesome"></i></div>
        <p>Castles</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Amazing pools" class="category-link-reset">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing pools</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Camping" class="category-link-reset">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Farms" class="category-link-reset">
        <div><i class="fa-solid fa-cow"></i></div>
        <p>Farms</p>
      </a>
    </div>
    <div class="filter">
      <a href="/listings/category/Boats" class="category-link-reset">
        <div><i class="fa-solid fa-ship"></i></div>
        <p>Boats</p>
      </a>
    </div>
    <div class="filter  d-none d-xxl-block">
      <a href="/listings/category/Trekking" class="category-link-reset">
        <div><i class="fa-solid fa-person-hiking"></i></div>
        <p>Trekking</p>
      </a>
    </div>
    <!-- <div class="filter d-none d-xxxl-block">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p> -->
  </div>
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        role="switch"
        id="switchCheckDefault"
      />
      <label class="form-check-label me-2" for="switchCheckDefault"
        >Display total after taxes</label
      >
    </div>
  </div>
</div>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <%for(let listing of allListings){%>
  <a href="/listings/<%= listing._id %>" class="listing-link">
    <div class="card col listing-card">
      <img
        src="<%=listing.image.url%>"
        class="card-img-top"
        alt="Listing_image"
        style="height: 20rem"
      />
      <div class="card-img-overlay"></div>

      <div class="card-body">
        <p class="card-text">
          <b><%= listing.title %></b><br /><i
            class="fa-solid fa-location-dot location-icon"
          ></i>
          <%= listing.location %> ,&nbsp;<%=listing.country%><br />
          &#8377; <%= listing.price.toLocaleString("en-IN") %> /night
          <i class="tax-info"> &nbsp; +18% GST </i><br/>
          <i class="text-danger tax-info">Total price &nbsp;&#8377; <%= listing.price + (listing.price * 18/100) %> </i>
        </p>
      </div>
    </div>
  </a>
  <%}%>
</div>
<script src="/js/multipleSelect.js"></script>


